LIVE_TESTNET_PAYMENT_TOKEN_DECIMALS=6
LIVE_TESTNET_ESCROW_CONTRACT_ADDRESS=

# Live Mainnet is the real Agent route. Deploy QuotaDEXEscrow(gateway, mainnet USDC.e) and set this escrow address.
